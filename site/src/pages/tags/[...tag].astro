---
import Base from '../../layouts/Base.astro';
import { tagInfo } from '../../lib/meta-tags';
import { allArtifacts, type Artifact } from '../../lib/tagged-content';

export async function getStaticPaths() {
  const artifacts = await allArtifacts();
  const tags = new Set<string>();
  for (const a of artifacts) for (const t of a.tags) tags.add(t);
  return [...tags].map((tag) => ({
    params: { tag },
    props: { tag, entries: artifacts.filter((a) => a.tags.includes(tag)) },
  }));
}

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const { tag, entries } = Astro.props as { tag: string; entries: Artifact[] };
const info = tagInfo(tag);

// Group the tagged artifacts by kind so the inverse view stays legible.
const byKind = new Map<string, Artifact[]>();
for (const e of [...entries].sort((a, b) => a.title.localeCompare(b.title))) {
  if (!byKind.has(e.kind)) byKind.set(e.kind, []);
  byKind.get(e.kind)!.push(e);
}
---
<Base title={tag}>
  <a href={`${base}/tags/`} class="text-sm text-(--color-text-muted) no-underline hover:underline">← Tags</a>
  <div class="mt-3 mb-6">
    <h1 class="text-3xl font-bold mb-1 font-mono">
      <span class="text-(--color-text-muted)">{info?.namespace}/</span>{info?.leaf ?? tag}
    </h1>
    {info?.gloss && <p class="text-(--color-text-secondary) max-w-2xl m-0">{info.gloss}</p>}
    <p class="text-sm text-(--color-text-muted) mt-1">
      {info?.namespaceLabel}{info ? ' · ' : ''}{entries.length} {entries.length === 1 ? 'artifact' : 'artifacts'}
    </p>
  </div>

  {[...byKind.entries()].map(([kind, list]) => (
    <section class="mb-8">
      <h2 class="text-sm font-bold uppercase tracking-wider text-(--color-text-muted) mb-3">{kind} ({list.length})</h2>
      <ul class="list-none p-0 m-0 grid gap-3 sm:grid-cols-2">
        {list.map((e) => (
          <li>
            <a href={e.url} class="card">
              <div class="font-semibold text-(--color-text-primary)">{e.title}</div>
            </a>
          </li>
        ))}
      </ul>
    </section>
  ))}
</Base>
