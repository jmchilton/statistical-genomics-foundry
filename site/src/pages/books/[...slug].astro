---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import SourceMeta from '../../components/SourceMeta.astro';

export async function getStaticPaths() {
  const entries = await getCollection('books');
  return entries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;
---
<Base title={d.title}>
  <div data-pagefind-body>
    <SourceMeta
      source={d.source}
      sourceChapter={d.source_chapter}
      sourceUrl={d.source_url}
      license={d.license}
      licenseFile={d.license_file}
      attribution={d.attribution}
      derived={d.derived}
    />
    <article class="prose prose-slate max-w-none dark:prose-invert">
      <Content />
    </article>
  </div>
</Base>
