---
import Base from '../../layouts/Base.astro';
import { getLicenses } from '../../lib/licenses';

export async function getStaticPaths() {
  return getLicenses().map(license => ({
    params: { id: license.id },
    props: { license },
  }));
}

const { license } = Astro.props;

// Turn bare URLs into links while leaving the rest of the text verbatim.
type Segment = { text: string; href?: string };
const segments: Segment[] = [];
const urlRe = /https?:\/\/[^\s)]+/g;
let last = 0;
let match: RegExpExecArray | null;
while ((match = urlRe.exec(license.text)) !== null) {
  if (match.index > last) segments.push({ text: license.text.slice(last, match.index) });
  segments.push({ text: match[0], href: match[0] });
  last = match.index + match[0].length;
}
if (last < license.text.length) segments.push({ text: license.text.slice(last) });
---
<Base title={`License — ${license.filename}`} description={`License terms for ${license.filename}.`}>
  <article class="license" data-pagefind-body>
    <header class="license-header">
      <span class="license-eyebrow">
        <span class="license-eyebrow-rule" aria-hidden="true"></span>
        <span>imported-content license</span>
      </span>
      <h1 data-pagefind-meta="title">{license.filename}</h1>
    </header>
    <pre class="license-text">{segments.map(s => s.href
      ? <a href={s.href} class="license-link">{s.text}</a>
      : s.text)}</pre>
  </article>
</Base>

<style>
  .license {
    max-width: 58rem;
  }
  .license-header {
    margin-bottom: 1.5rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--color-border-subtle);
  }
  .license-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }
  .license-eyebrow-rule {
    width: 1.5rem;
    height: 2px;
    background: var(--color-accent);
  }
  .license-header h1 {
    margin: 0.55rem 0 0;
    color: var(--color-text-primary);
    font-family: var(--font-mono);
    font-size: clamp(1.3rem, 1.6vw + 0.5rem, 1.7rem);
    letter-spacing: -0.01em;
  }
  .license-text {
    margin: 0;
    padding: 1.25rem 1.4rem;
    border: 1px solid var(--color-border-subtle);
    border-radius: 0.5rem;
    background: var(--color-surface-raised);
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    line-height: 1.65;
    white-space: pre-wrap;
    word-break: break-word;
  }
  .license-link {
    color: var(--color-link);
  }
  .license-link:hover {
    color: var(--color-link-hover);
  }
</style>
