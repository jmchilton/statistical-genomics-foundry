---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { DESIGN_DOCS, renderDesignDoc } from '../../lib/design-docs';
import { buildWikiLinkMap } from '../../lib/wiki-links';

export async function getStaticPaths() {
  return DESIGN_DOCS.map(doc => ({
    params: { slug: doc.slug },
    props: { doc },
  }));
}

const { doc } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const linkMap = buildWikiLinkMap(await getCollection('corpus'));
const html = renderDesignDoc(doc, linkMap, base);

const group = DESIGN_DOCS.filter(d => d.category === doc.category);
const idx = group.findIndex(d => d.slug === doc.slug);
const previous = idx > 0 ? group[idx - 1] : undefined;
const next = idx >= 0 && idx < group.length - 1 ? group[idx + 1] : undefined;
const kind = doc.category === 'research' ? 'prior-art research' : 'design record';
---
<Base title={doc.title} description={doc.summary}>
  <article class="design-doc" data-pagefind-body>
    <header class="design-doc-header">
      <a href={`${base}/design/`} class="design-back">
        <span aria-hidden="true">&larr;</span> Design docs
      </a>
      <span class="design-eyebrow">
        <span class="design-eyebrow-rule" aria-hidden="true"></span>
        <span>{kind}</span>
      </span>
      <h1 data-pagefind-meta="title">{doc.title}</h1>
      <p data-pagefind-meta="summary">{doc.summary}</p>
    </header>

    <div class="prose prose-slate max-w-none dark:prose-invert" set:html={html} />

    <nav class="design-doc-nav" aria-label="Design doc navigation">
      {previous ? (
        <a href={`${base}/design/${previous.slug}/`}>
          <small>Previous</small>
          <span>{previous.title}</span>
        </a>
      ) : <span></span>}
      {next ? (
        <a href={`${base}/design/${next.slug}/`} class="design-doc-nav-next">
          <small>Next</small>
          <span>{next.title}</span>
        </a>
      ) : <span></span>}
    </nav>
  </article>
</Base>

<style>
  .design-doc {
    max-width: 58rem;
  }
  .design-doc-header {
    margin-bottom: 1.75rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--color-border-subtle);
  }
  .design-back {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    color: var(--color-text-muted);
    font-size: 0.75rem;
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .design-back:hover {
    color: var(--color-link);
  }
  .design-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.65rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }
  .design-eyebrow-rule {
    width: 1.5rem;
    height: 2px;
    background: var(--color-accent);
  }
  .design-doc-header h1 {
    margin: 0.4rem 0 0;
    color: var(--color-text-primary);
    font-size: clamp(1.9rem, 3.2vw + 0.5rem, 2.8rem);
    line-height: 1.08;
    letter-spacing: -0.02em;
    text-wrap: balance;
  }
  .design-doc-header p {
    margin: 0.65rem 0 0;
    max-width: 65ch;
    color: var(--color-text-secondary);
    font-size: 1rem;
    line-height: 1.58;
    text-wrap: pretty;
  }
  .design-doc-nav {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
    margin-top: 2.25rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border-subtle);
  }
  .design-doc-nav a {
    display: grid;
    gap: 0.2rem;
    padding: 0.8rem 0.9rem;
    color: inherit;
    text-decoration: none;
    border: 1px solid var(--color-border-subtle);
    border-radius: 0.4rem;
    background: var(--color-surface-raised);
    transition: border-color 0.15s ease, transform 0.15s ease;
  }
  .design-doc-nav a:hover {
    border-color: var(--color-accent);
    transform: translateY(-1px);
  }
  .design-doc-nav small {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .design-doc-nav span {
    color: var(--color-link);
    font-weight: 700;
  }
  .design-doc-nav-next {
    text-align: right;
  }
  @media (max-width: 560px) {
    .design-doc-nav {
      grid-template-columns: 1fr;
    }
    .design-doc-nav-next {
      text-align: left;
    }
  }
</style>
