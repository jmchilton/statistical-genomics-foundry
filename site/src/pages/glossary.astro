---
import path from 'node:path';
import Base from '../layouts/Base.astro';
import { buildWikiLinkMap } from '../lib/wiki-links';
import { DESIGN_DOCS } from '../lib/design-docs';
import { renderVaultDoc } from '../lib/render-vault-doc';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const linkMap = buildWikiLinkMap(DESIGN_DOCS);
const html = renderVaultDoc(path.resolve('../content/meta/glossary.md'), linkMap, base);
---
<Base title="Glossary" description="Pinned definitions for Statistical Genomics Foundry terminology.">
  <article class="prose prose-slate max-w-none dark:prose-invert" data-pagefind-body set:html={html} />
</Base>
