---
// Source/license box, shared by books (license_file → in-app license page) and
// source notes (papers/tutorials: free-text license, no license file; optional
// DOI/version/access-date pins).
interface Props {
  source: string;
  sourceChapter?: number;
  sourceUrl: string;
  license: string;
  licenseFile?: string;
  attribution: string;
  doi?: string;
  version?: string;
  accessDate?: string;
}
import { licenseIdFromFile } from '../lib/licenses';
const { source, sourceChapter, sourceUrl, license, licenseFile, attribution, doi, version, accessDate } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const licenseHref = licenseFile ? `${base}/licenses/${licenseIdFromFile(licenseFile)}/` : null;
const doiHref = doi ? `https://doi.org/${doi}` : null;
---
<aside class="not-prose mb-6 rounded-lg border border-(--color-border-subtle) bg-(--color-surface-raised) p-4 text-sm">
  <div class="flex flex-wrap items-center gap-2 mb-2">
    <span class="tag">{source}{sourceChapter !== undefined ? ` · ch ${sourceChapter}` : ''}</span>
    {version && <span class="tag">{version}</span>}
    <span class="tag">{license}</span>
  </div>
  <p class="text-(--color-text-secondary) m-0">
    {attribution}
  </p>
  <p class="text-(--color-text-muted) mt-2 mb-0">
    <a href={sourceUrl} class="text-(--color-link) hover:text-(--color-link-hover)">Original source ↗</a>
    {doiHref && (<><span aria-hidden="true"> · </span><a href={doiHref} class="text-(--color-link) hover:text-(--color-link-hover)">doi:{doi}</a></>)}
    {licenseHref && (<><span aria-hidden="true"> · </span><a href={licenseHref} class="text-(--color-link) hover:text-(--color-link-hover)">License terms</a></>)}
    {accessDate && <span class="text-(--color-text-muted)"> · accessed {accessDate}</span>}
  </p>
</aside>
