---
import Base from '../../layouts/Base.astro';
import { DESIGN_DOC_GROUPS, designDocsByCategory } from '../../lib/design-docs';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Base
  title="Design Docs"
  description="Design records and prior-art research for the Statistical Genomics Foundry."
>
  <section class="design-hero" aria-labelledby="design-heading">
    <span class="eyebrow mb-4">Design Record</span>
    <h1 id="design-heading">The working record behind the Foundry.</h1>
    <p>
      The rationale and the landscape: positioning, principles, the referee loop, architecture,
      Molds, casting, and corpus grounding — plus the prior-art surveys and verification reports
      that shape what gets built.
    </p>
  </section>

  {DESIGN_DOC_GROUPS.map(group => {
    const docs = designDocsByCategory(group.category);
    return (
      <section class="design-doc-section" aria-labelledby={`design-${group.category}`}>
        <div class="design-section-heading">
          <div>
            <h2 id={`design-${group.category}`}>{group.title}</h2>
            <p>{group.summary}</p>
          </div>
          <span class="font-mono">{docs.length} records</span>
        </div>
        <div class="design-doc-grid">
          {docs.map((doc, index) => (
            <a href={`${base}/design/${doc.slug}/`} class="design-doc-card">
              <span class="design-doc-num font-mono">{String(index + 1).padStart(2, '0')}</span>
              <span class="design-doc-title">{doc.title}</span>
              <span class="design-doc-summary">{doc.summary}</span>
              <span class="design-doc-source font-mono">{group.action}</span>
            </a>
          ))}
        </div>
      </section>
    );
  })}
</Base>

<style>
  .design-hero {
    padding: 1.5rem 0 1.25rem;
    max-width: 58rem;
  }
  .design-hero h1 {
    margin: 0 0 1rem;
    color: var(--color-galaxy-dark);
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 1.04;
    letter-spacing: -0.025em;
    text-wrap: balance;
  }
  .dark .design-hero h1 {
    color: var(--color-text-primary);
  }
  .design-hero p {
    margin: 0;
    color: var(--color-text-secondary);
    font-size: 1.05rem;
    line-height: 1.72;
    text-wrap: pretty;
  }
  .design-doc-section {
    margin-top: 2rem;
  }
  .design-section-heading {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: end;
    margin-bottom: 0.8rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-border-subtle);
  }
  .design-section-heading h2 {
    margin: 0;
    color: var(--color-text-primary);
    font-size: 1.15rem;
    line-height: 1.2;
  }
  .design-section-heading p {
    margin: 0.35rem 0 0;
    max-width: 62ch;
    color: var(--color-text-secondary);
    font-size: 0.92rem;
    line-height: 1.55;
    text-wrap: pretty;
  }
  .design-section-heading span {
    flex-shrink: 0;
    color: var(--color-text-muted);
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .design-doc-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.85rem;
  }
  .design-doc-card {
    display: grid;
    grid-template-rows: auto auto 1fr auto;
    gap: 0.55rem;
    min-height: 13rem;
    padding: 1rem;
    color: inherit;
    text-decoration: none;
    border: 1px solid var(--color-border-subtle);
    border-radius: 0.5rem;
    background: var(--color-surface-raised);
    transition: border-color 0.18s ease, transform 0.18s ease;
  }
  .design-doc-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
  }
  .design-doc-num {
    color: var(--color-accent);
    font-size: 0.78rem;
    letter-spacing: 0.12em;
  }
  .design-doc-title {
    color: var(--color-text-primary);
    font-weight: 700;
    font-size: 1.18rem;
    line-height: 1.18;
  }
  .design-doc-summary {
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    line-height: 1.55;
    text-wrap: pretty;
  }
  .design-doc-source {
    color: var(--color-text-muted);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
  }
  @media (max-width: 900px) {
    .design-doc-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  @media (max-width: 560px) {
    .design-section-heading {
      display: block;
    }
    .design-section-heading span {
      display: inline-block;
      margin-top: 0.65rem;
    }
    .design-doc-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
