---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const entries = (await getCollection('experiments')).sort((a, b) => a.id.localeCompare(b.id));

// Each experiment folder (ingest-<subject>) holds one or more Mold artifacts — a
// candidate-mold, or a doer/audit pair, or a hardened pair. Group by that folder.
const familyOf = (tags: string[]) => tags.find(t => t.startsWith('family/'))?.split('/')[1] ?? null;
const roleOf = (tags: string[]) => tags.find(t => t.startsWith('role/'))?.split('/')[1] ?? null;

const groups = new Map<string, typeof entries>();
for (const e of entries) {
  const key = e.id.split('/')[0];
  if (!groups.has(key)) groups.set(key, [] as unknown as typeof entries);
  groups.get(key)!.push(e);
}
---
<Base title="Experiments">
  <span class="eyebrow mb-3">Experiments</span>
  <h1 class="text-3xl font-bold mb-2">Experiments</h1>
  <p class="text-(--color-text-secondary) max-w-2xl mb-8">
    Blind-assembly probes: doer/referee Mold pairs assembled from ingested source notes
    <strong>alone</strong> — never the source skill — then diffed against it. The deliverable
    is the diff; these Molds are the probe artifacts. They are structurally Molds but
    cataloged apart from the authored Mold set.
  </p>
  <p class="text-sm text-(--color-text-muted) mb-8">{entries.length} artifacts across {groups.size} probes</p>

  {[...groups.entries()].map(([probe, list]) => (
    <section class="mb-8" aria-labelledby={`probe-${probe}`}>
      <h2 id={`probe-${probe}`} class="text-sm font-bold uppercase tracking-wider text-(--color-text-muted) mb-3 font-mono">{probe}</h2>
      <ul class="list-none p-0 m-0 grid gap-3 sm:grid-cols-2">
        {list.map(e => {
          const family = familyOf(e.data.tags);
          const role = roleOf(e.data.tags);
          return (
            <li>
              <a href={`${base}/experiments/${e.id}/`} class="card flex flex-col">
                <div class="font-mono font-semibold text-(--color-text-primary)">{e.data.name}</div>
                <div class="text-xs text-(--color-text-muted) mt-1">{e.id.slice(probe.length + 1)}</div>
                <div class="flex flex-wrap items-center gap-2 mt-3 text-xs text-(--color-text-muted)">
                  {family && <span>Family {family.toUpperCase()}</span>}
                  {role && <span class="rounded bg-(--color-galaxy-primary) text-(--color-text-on-dark) px-1.5 py-0.5 font-mono">{role}</span>}
                </div>
              </a>
            </li>
          );
        })}
      </ul>
    </section>
  ))}
</Base>
