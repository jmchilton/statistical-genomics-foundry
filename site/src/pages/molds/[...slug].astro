---
import { getCollection, render } from 'astro:content';
import { existsSync } from 'node:fs';
import { fileURLToPath } from 'node:url';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const entries = await getCollection('molds');
  return entries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;

const hasSibling = (file: string) =>
  existsSync(fileURLToPath(new URL(`../../../../content/molds/${entry.id}/${file}`, import.meta.url)));
---
<Base title={d.name}>
  <div data-pagefind-body>
    <a href={`${base}/molds/`} class="text-sm text-(--color-text-muted) no-underline hover:underline">← Molds</a>
    <div class="flex flex-wrap items-center gap-2 mt-3 mb-6 text-xs">
      {d.tags.map(t => <span class="rounded bg-(--color-surface-raised) border border-(--color-border-subtle) text-(--color-text-secondary) px-2 py-0.5 font-mono">{t}</span>)}
      <span class="text-(--color-text-muted)">eval {hasSibling('eval.md') ? '✓' : '—'} · scenarios {hasSibling('scenarios.md') ? '✓' : '—'}</span>
    </div>
    <article class="prose prose-slate max-w-none dark:prose-invert">
      <Content />
    </article>
  </div>
</Base>
