---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import { roleOf, familyOf } from '../lib/tags';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const bookCount = (await getCollection('books')).length;
const paperCount = (await getCollection('papers')).length;
const tutorialCount = (await getCollection('tutorials')).length;
const patternCount = (await getCollection('patterns')).length;
const experimentCount = (await getCollection('experiments')).length;

const molds = (await getCollection('molds')).sort((a, b) => a.data.name.localeCompare(b.data.name));
---
<Base title="Statistical Genomics Foundry">
  <section class="mb-12">
    <span class="eyebrow mb-4">Statistical Genomics Foundry</span>
    <h1 class="text-4xl sm:text-5xl font-bold text-balance text-(--color-galaxy-dark) dark:text-(--color-text-primary) mb-4">
      Productive <span class="text-(--color-galaxy-primary) dark:text-(--color-accent)">and</span> statistically honest.
    </h1>
    <p class="max-w-3xl text-lg text-(--color-text-secondary) text-pretty mb-6">
      A knowledge base of agent skills that keeps analytical work both productive and
      statistically honest — using established methods correctly instead of inventing
      plausible-sounding ones, respecting each method's preconditions, and grounding claims
      in empirical checks rather than a method's name or a significant-looking number.
    </p>
    <a href={`${base}/books/`} class="inline-flex items-center gap-2 rounded-md bg-(--color-galaxy-primary) text-(--color-text-on-dark) px-4 py-2 no-underline hover:bg-(--color-galaxy-dark) transition-colors">
      Browse the books
      <span aria-hidden="true">→</span>
    </a>
  </section>

  {molds.length > 0 && (
    <section class="mb-12" aria-labelledby="molds-heading">
      <div class="flex items-baseline justify-between mb-3">
        <h2 id="molds-heading" class="text-sm font-bold uppercase tracking-wider text-(--color-text-muted)">Molds</h2>
        <a href={`${base}/molds/`} class="text-sm text-(--color-galaxy-primary) dark:text-(--color-accent) no-underline hover:underline">All molds →</a>
      </div>
      <p class="text-sm text-(--color-text-secondary) max-w-3xl mb-4">
        The Mold-primary core — abstract action templates cast into self-contained skills.
        Family A does the analysis; Family B referees it, so doing never self-certifies.
      </p>
      <ul class="list-none p-0 m-0 grid gap-3 sm:grid-cols-2">
        {molds.map(m => {
          const role = roleOf(m.data.tags);
          const family = familyOf(m.data.tags);
          return (
            <li>
              <a href={`${base}/molds/${m.id}/`} class="card flex flex-col">
                <div class="font-mono font-semibold text-(--color-text-primary)">{m.data.name}</div>
                {m.data.summary && <div class="text-sm text-(--color-text-secondary) mt-1 grow">{m.data.summary}</div>}
                <div class="flex flex-wrap items-center gap-2 mt-3 text-xs text-(--color-text-muted)">
                  {family && <span>Family {family.toUpperCase()}</span>}
                  {role && <span class="rounded bg-(--color-galaxy-primary) text-(--color-text-on-dark) px-1.5 py-0.5 font-mono">{role}</span>}
                </div>
              </a>
            </li>
          );
        })}
      </ul>
    </section>
  )}

  <section aria-labelledby="research-heading" class="mb-12">
    <h2 id="research-heading" class="text-sm font-bold uppercase tracking-wider text-(--color-text-muted) mb-3">Research</h2>
    <p class="text-sm text-(--color-text-secondary) max-w-3xl mb-4">
      The grounding corpus — faithful, recoverable source notes that back the Molds. Not reproductions.
    </p>
    <ul class="list-none p-0 m-0 grid gap-3 sm:grid-cols-2">
      <li>
        <a href={`${base}/books/`} class="card">
          <div class="font-semibold text-(--color-text-primary) mb-1">Books</div>
          <div class="text-sm text-(--color-text-secondary)">
            {bookCount} own-words summaries of external textbooks, each carrying its license and attribution.
          </div>
        </a>
      </li>
      <li>
        <a href={`${base}/papers/`} class="card">
          <div class="font-semibold text-(--color-text-primary) mb-1">Papers</div>
          <div class="text-sm text-(--color-text-secondary)">
            {paperCount} faithful research notes on primary papers, each with citation and a link to the source.
          </div>
        </a>
      </li>
      <li>
        <a href={`${base}/tutorials/`} class="card">
          <div class="font-semibold text-(--color-text-primary) mb-1">Tutorials</div>
          <div class="text-sm text-(--color-text-secondary)">
            {tutorialCount} notes on tool vignettes — procedure, exact defaults, pinned to the version summarized.
          </div>
        </a>
      </li>
      {patternCount > 0 && (
        <li>
          <a href={`${base}/patterns/`} class="card">
            <div class="font-semibold text-(--color-text-primary) mb-1">Patterns</div>
            <div class="text-sm text-(--color-text-secondary)">
              {patternCount} corpus leaves — named invalidity signatures and established-good practice the referee Molds delegate to.
            </div>
          </a>
        </li>
      )}
      {experimentCount > 0 && (
        <li>
          <a href={`${base}/experiments/`} class="card">
            <div class="font-semibold text-(--color-text-primary) mb-1">Experiments</div>
            <div class="text-sm text-(--color-text-secondary)">
              {experimentCount} blind-assembly artifacts — candidate doer/audit Mold pairs authored from source notes, then diffed against the target skill.
            </div>
          </a>
        </li>
      )}
    </ul>
  </section>

  <section aria-labelledby="reference-heading">
    <h2 id="reference-heading" class="text-sm font-bold uppercase tracking-wider text-(--color-text-muted) mb-3">Reference</h2>
    <p class="text-sm text-(--color-text-secondary) max-w-3xl mb-4">
      The project's own vocabulary and rationale — how the Foundry is built and why.
    </p>
    <ul class="list-none p-0 m-0 grid gap-3 sm:grid-cols-2">
      <li>
        <a href={`${base}/design/`} class="card">
          <div class="font-semibold text-(--color-text-primary) mb-1">Design Docs</div>
          <div class="text-sm text-(--color-text-secondary)">
            The rationale and prior-art research behind the Foundry — positioning, the referee loop, and the landscape it's built against.
          </div>
        </a>
      </li>
      <li>
        <a href={`${base}/glossary/`} class="card">
          <div class="font-semibold text-(--color-text-primary) mb-1">Glossary</div>
          <div class="text-sm text-(--color-text-secondary)">
            Pinned definitions for Foundry terminology.
          </div>
        </a>
      </li>
    </ul>
  </section>
</Base>
