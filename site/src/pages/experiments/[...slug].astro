---
import { getCollection, render } from 'astro:content';
import { existsSync } from 'node:fs';
import { fileURLToPath } from 'node:url';
import Base from '../../layouts/Base.astro';
import ArtifactMeta from '../../components/ArtifactMeta.astro';

export async function getStaticPaths() {
  const entries = await getCollection('experiments');
  return entries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;

const hasSibling = (file: string) =>
  existsSync(fileURLToPath(new URL(`../../../../content/research/experiments/${entry.id}/${file}`, import.meta.url)));
---
<Base title={d.name}>
  <div data-pagefind-body>
    <a href={`${base}/experiments/`} class="text-sm text-(--color-text-muted) no-underline hover:underline">← Experiments</a>
    <ArtifactMeta kind="experiment" tags={d.tags} />
    <div class="flex flex-wrap items-center gap-2 -mt-3 mb-6 text-xs text-(--color-text-muted)">
      <span>eval {hasSibling('eval.md') ? '✓' : '—'} · scenarios {hasSibling('scenarios.md') ? '✓' : '—'}</span>
    </div>
    <article class="prose prose-slate max-w-none dark:prose-invert">
      <Content />
    </article>
  </div>
</Base>
